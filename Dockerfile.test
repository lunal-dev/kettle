FROM rust:1.90-slim

# Install Python and git
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create a test Rust project
WORKDIR /test-project
RUN cargo init --bin --name test-app

# Add some dependencies (append to existing [dependencies] section)
RUN echo 'serde = { version = "1.0", features = ["derive"] }\nserde_json = "1.0"' >> Cargo.toml

# Generate lockfile and fetch deps (creates clean cargo cache)
RUN cargo generate-lockfile && cargo fetch

# Initialize git repo (required for attestable builds)
RUN git config --global user.email "test@example.com" && \
    git config --global user.name "Test User" && \
    git init && \
    git add . && \
    git commit -m "Initial commit"

# Copy attestable-builds into the container
WORKDIR /attestable-builds
COPY . .

# Install attestable-builds with dependencies
RUN pip3 install -e . --break-system-packages

# Set working directory back to test project
WORKDIR /test-project

# Default command: run the attestable build
CMD ["python3", "-m", "attestable_builds.cli", "build", ".", "-v"]
